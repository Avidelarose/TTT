        { id: 329, text: "Почему необходимо контролировать мощность фотополимеризационной лампы?", options: ["A. Для выбора оттенка", "B. Для обеспечения достаточной энергии полимеризации", "C. Для контроля влажности", "D. Для оценки гибридного слоя", "E. Для измерения С-фактора"], correct: 1 },
        { id: 330, text: "Какая ошибка чаще всего приводит к чувствительности после реставрации?", options: ["A. Избыточная полировка", "B. Нарушение адгезивного протокола и микроподтекание", "C. Использование коффердама", "D. Селективное травление эмали", "E. Контроль окклюзии"], correct: 1 }
    ];
    block64.forEach(q => { q.block = "Блок 64. Ошибки фотополимеризации"; extra.push(q); });

    // ===== БЛОК 65 ===== (331–335)
    const block65 = [
        { id: 331, text: "Через 48 часов после реставрации пациент отмечает кратковременную боль только от холодного. Самопроизвольных болей нет. Наиболее вероятная причина:", options: ["A. Некроз пульпы", "B. Послеоперационная чувствительность вследствие нарушения адгезии", "C. Острый апикальный периодонтит", "D. Вертикальный перелом корня", "E. Абсцесс"], correct: 1 },
        { id: 332, text: "Какой этап адгезивного протокола чаще всего нарушается начинающими врачами?", options: ["A. Полировка", "B. Испарение растворителя", "C. Артикуляционная коррекция", "D. Выбор оттенка", "E. Финишная обработка"], correct: 1 },
        { id: 333, text: "Какой клинический симптом больше говорит о проблеме адгезии, чем о пульпите?", options: ["A. Ночная самопроизвольная боль", "B. Длительная боль от горячего", "C. Кратковременная боль от холодного после реставрации", "D. Положительная перкуссия", "E. Отек"], correct: 2 },
        { id: 334, text: "Какой метод наиболее эффективно снижает риск послеоперационной чувствительности?", options: ["A. Увеличение времени травления дентина", "B. Строгое соблюдение адгезивного протокола", "C. Использование только текучего композита", "D. Отказ от коффердама", "E. Увеличение толщины композита"], correct: 1 },
        { id: 335, text: "Главная причина долгосрочного успеха адгезивной реставрации:", options: ["A. Цвет композита", "B. Герметичный и стабильный адгезивный интерфейс", "C. Толщина эмали", "D. Возраст пациента", "E. Вид матрицы"], correct: 1 }
    ];
    block65.forEach(q => { q.block = "Блок 65. Клинические ситуации (уровень аккредитации)"; extra.push(q); });

    // Собираем все в один массив
    const allExtra = [].concat(
        block21, block22, block23, block24, block25,
        block26, block27, block28,
        block34, block35, block36, block37, block38, block39,
        block40, block41, block42, block43, block44,
        block45, block46, block47, block48, block49, block50,
        block51, block52, block53, block54, block55,
        block56, block57, block58, block59, block60,
        block61, block62, block63, block64, block65
    );

    allExtra.forEach(q => extra.push(q));
    return extra;
}

// Собираем полный массив вопросов
const fullQuestions = allQuestions.concat(generateRemainingQuestions());

// ============================================================
// ИНИЦИАЛИЗАЦИЯ ТЕСТА
// ============================================================
let userAnswers = {};

// Функция перемешивания (Fisher-Yates)
function shuffleArray(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
}

// Перемешиваем варианты ответов для каждого вопроса
fullQuestions.forEach(q => {
    // Создаём массив с индексами и перемешиваем
    const indices = q.options.map((_, i) => i);
    shuffleArray(indices);
    // Переставляем варианты и правильный ответ
    const shuffledOptions = indices.map(i => q.options[i]);
    const newCorrect = indices.indexOf(q.correct);
    q.options = shuffledOptions;
    q.correct = newCorrect;
});

// Группируем по блокам
const blocks = {};
fullQuestions.forEach(q => {
    if (!blocks[q.block]) blocks[q.block] = [];
    blocks[q.block].push(q);
});

// Строим оглавление
const tocContainer = document.getElementById('tocContainer');
Object.keys(blocks).forEach(blockName => {
    const id = 'block-' + blockName.replace(/[^a-zA-Z0-9]/g, '-');
    const a = document.createElement('a');
    a.href = '#' + id;
    a.textContent = blockName.replace('Блок ', 'Б.');
    tocContainer.appendChild(a);
});

// Рендерим тест
const container = document.getElementById('testContainer');
let html = '';
Object.keys(blocks).forEach(blockName => {
    const id = 'block-' + blockName.replace(/[^a-zA-Z0-9]/g, '-');
    html += `<div class="block" id="${id}"><div class="block-title">${blockName}</div>`;
    blocks[blockName].forEach(q => {
        html += `
            <div class="question" id="q-${q.id}">
                <div class="qhead">
                    <span class="qnum">Вопрос ${q.id}</span>
                </div>
                <div class="qtext">${q.text}</div>
                <ul class="options">
        `;
        q.options.forEach((opt, idx) => {
            const letter = String.fromCharCode(65 + idx);
            html += `
                <li data-q="${q.id}" data-opt="${idx}">
                    <label>
                        <input type="radio" name="q${q.id}" value="${idx}" />
                        ${letter}. ${opt}
                    </label>
                </li>
            `;
        });
        html += `
                </ul>
            </div>
        `;
    });
    html += `</div>`;
});
container.innerHTML = html;

// ============================================================
// ЛОГИКА ТЕСТА
// ============================================================

// Обработка кликов по вариантам
document.querySelectorAll('.options li').forEach(li => {
    li.addEventListener('click', function(e) {
        const radio = this.querySelector('input[type="radio"]');
        if (radio) {
            radio.checked = true;
            // Убираем выделение у других вариантов в этом вопросе
            const parent = this.closest('.options');
            parent.querySelectorAll('li').forEach(item => item.classList.remove('selected'));
            this.classList.add('selected');
            // Сохраняем ответ
            const qId = parseInt(this.dataset.q);
            const opt = parseInt(this.dataset.opt);
            userAnswers[qId] = opt;
            updateStats();
        }
    });
});

// Обновление статистики
function updateStats() {
    const total = fullQuestions.length;
    const answered = Object.keys(userAnswers).length;
    document.getElementById('answeredCount').textContent = answered;
    document.getElementById('remainingCount').textContent = total - answered;
    const pct = (answered / total) * 100;
    document.getElementById('progressBar').style.width = pct + '%';
}

// Сброс
document.getElementById('resetBtn').addEventListener('click', function() {
    if (!confirm('Сбросить все ответы?')) return;
    userAnswers = {};
    document.querySelectorAll('.options li').forEach(li => {
        li.classList.remove('selected');
        const radio = li.querySelector('input[type="radio"]');
        if (radio) radio.checked = false;
    });
    document.querySelectorAll('.question').forEach(q => {
        q.classList.remove('correct', 'wrong');
    });
    document.getElementById('resultPanel').classList.remove('show');
    updateStats();
    window.scrollTo({ top: 0, behavior: 'smooth' });
});

// Завершение теста
document.getElementById('finishBtn').addEventListener('click', function() {
    const total = fullQuestions.length;
    const answered = Object.keys(userAnswers).length;
    if (answered < total) {
        if (!confirm(`Вы ответили только на ${answered} из ${total} вопросов. Завершить тест?`)) {
            return;
        }
    }

    let correctCount = 0;
    let errors = [];

    fullQuestions.forEach(q => {
        const userAns = userAnswers[q.id];
        const isCorrect = (userAns !== undefined && userAns === q.correct);
        if (isCorrect) correctCount++;
        else {
            errors.push({
                id: q.id,
                text: q.text,
                user: userAns !== undefined ? q.options[userAns] : 'Не отвечен',
                correct: q.options[q.correct]
            });
        }
        // Подсветка вопроса
        const el = document.getElementById('q-' + q.id);
        if (el) {
            el.classList.remove('correct', 'wrong');
            if (userAns !== undefined) {
                el.classList.add(isCorrect ? 'correct' : 'wrong');
            }
        }
    });

    const pct = Math.round((correctCount / total) * 100);
    document.getElementById('resultPanel').classList.add('show');
    document.getElementById('scoreDisplay').textContent = `${correctCount} из ${total} (${pct}%)`;

    let msg = '';
    if (pct >= 90) msg = '🎉 Отлично! Вы блестяще знаете материал!';
    else if (pct >= 70) msg = '👍 Хороший результат! Есть над чем поработать.';
    else if (pct >= 50) msg = '📖 Средний результат. Рекомендуем повторить материал.';
    else msg = '📚 Низкий результат. Стоит серьёзно изучить тему.';
    document.getElementById('scoreMessage').textContent = msg;

    // Детали ошибок
    const detailDiv = document.getElementById('errorsDetail');
    if (errors.length === 0) {
        detailDiv.innerHTML = '<p style="color:#1a7a3f;font-weight:600;">✅ Все вопросы отвечены верно!</p>';
    } else {
        let errHtml = `<p><strong>Ошибки (${errors.length}):</strong></p>`;
        errors.forEach(e => {
            errHtml += `
                <div class="detail-item">
                    <div class="q">Вопрос ${e.id}: ${e.text}</div>
                    <div class="your">❌ Ваш ответ: ${e.user}</div>
                    <div class="correct-ans">✅ Правильный ответ: ${e.correct}</div>
                </div>
            `;
        });
        detailDiv.innerHTML = errHtml;
    }

    window.scrollTo({ top: document.getElementById('resultPanel').offsetTop - 20, behavior: 'smooth' });
});

// Инициализация статистики
document.getElementById('totalCount').textContent = fullQuestions.length;
updateStats();

// Автосохранение ответов при перезагрузке (опционально)
window.addEventListener('beforeunload', function() {
    // Можно сохранять в localStorage при желании
});

console.log('✅ Тест загружен. Всего вопросов:', fullQuestions.length);
</script>
